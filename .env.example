# LLM Provider — choose 'together' or 'anthropic'
LLM_PROVIDER=together

# Together AI (https://api.together.ai)
TOGETHER_API_KEY=
# Kimi K2 — good instruction-following, multilingual, cost-effective
TOGETHER_CLASSIFIER_MODEL=moonshotai/Kimi-K2-Instruct
TOGETHER_JUDGE_MODEL=moonshotai/Kimi-K2-Instruct

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-6

# Database
DB_PATH=./data/lighthouse.db

# WhatsApp / Baileys
WA_AUTH_DIR=./src/whatsapp/auth

# Logging
LOG_LEVEL=info

# Behavior
# Set to 'true' to enable the bot to send DMs. Keep 'false' until you're confident.
ENABLE_OUTBOUND_DMS=false

# Dashboard
WEB_PORT=3000
